{
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**"
  ],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo",

    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "jsx": "react-jsx",

    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": true,

    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/lib/utils": ["./frontend/src/lib/ui.helper.ts"],
      "@/lib/queryClient": ["./frontend/src/utils/query-client.ts"],
      "@/lib/export": ["./frontend/src/lib/export.helper.ts"],
      "@/lib/job-simulator": ["./frontend/src/lib/job-simulator.helper.ts"],
      "@/data/quizData": ["./shared/constants/quiz-data.constants.ts"],
      "@/*": ["./frontend/src/*"],
      "@shared/schema": ["./shared/schemas/schema.ts"],
      "@shared/*": ["./shared/*"],
      "@server/*": ["./backend/src/*"],
      "@admin/*": ["./admin/*"]
    }
  }
}
