# ==============================================================================
# Quantum Computing Job Tracker Dashboard — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your real values.
# This file is SAFE to commit. Never commit the actual .env file.

# --- Server ---
PORT=5000
NODE_ENV=development
SESSION_SECRET=CHANGE_ME_use_a_long_random_secret_string
APP_URL=http://localhost:5000

# --- Database ---
DATABASE_URL=postgres://username:password@localhost:5432/quantum_job_tracker
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require

# --- IBM Quantum ---
IBM_QUANTUM_API_TOKEN=your_ibm_quantum_api_token
IBM_QUANTUM_PROJECT_ID=your_project_id
IBM_QUANTUM_INSTANCE_ID=your_instance_crn_id
IBM_QUANTUM_HUB=ibm-q
IBM_QUANTUM_GROUP=open
IBM_QUANTUM_REGION=us-east

# --- OpenAI ---
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- SMTP Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@domain.com
SMTP_PASS=your_smtp_app_password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Quantum Job Tracker

# --- Maps ---
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token
VITE_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_TLS=false
REDIS_SESSION_TTL=86400

# --- JWT ---
JWT_SECRET=your_minimum_32_char_jwt_secret_key
JWT_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:5000,http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=10

# --- WebSockets ---
WS_PORT=5001
WS_HEARTBEAT_INTERVAL=30000

# --- Vite Client Variables ---
VITE_API_BASE_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5001
VITE_APP_URL=http://localhost:5000

# --- Logging ---
LOG_LEVEL=debug
LOG_FORMAT=dev

# --- Uploads ---
MAX_UPLOAD_SIZE_MB=50
EXPORT_RATE_LIMIT_PER_MINUTE=5
